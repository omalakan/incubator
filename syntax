; MULTIX System Assembly
; Демо: Мінімалізм і ручні стеки

RAM 0x8000

# 0 RAM
    x31 RAM + 0x1000        ; Ініціалізація стека повернень
    x10 0xAA                ; Аргумент лежить в x10

    ; Якщо
    ? x1
        ; код
    :? !x1 ; інакше якщо
        ; код
    :      ; інакше
        ; код

    ; switch/select
    ? x5
    : < x1
        ; код
    : > x2
        ; код
    : x3
        ; код
    :
        ; код
        

    process -s0             ; Виклик. (Сховали тільки адресу повернення!)
    
    ; Коли ми повернемось, результат вже буде в x11. 
    ; Стек для даних ми не чіпали взагалі!
    _                       ; Halt

process
    ; Ми знаємо, що аргумент чекає на нас у x10
    x11 x10 + 1             ; Робота: x11 = x10 + 1

    $ x1 < x2               ; Цикл поки x1 < x2
        [x4] x3             ; Запис за адресою
    
    s0+                     ; Return (Дістали адресу зі стека і стрибнули)

