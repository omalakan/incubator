; MULTIX System Assembly
; Демо: Мінімалізм і ручні стеки

RAM 0x8000

: RAM
; Ініціалізація стека
x31 RAM + 0x1000        

; Аргумент
x10 0xAA   
; Push аргумента
[--x31] x10             

; Call функції 'process'
process [--x31]         

; Pop результату
x11 [x31++]             
; Halt
_                       

process:
; Pop аргумента в x5
x5 [x31++]             
; Робота
x5 x5 + 1              

; Push результату
[--x31] x5      
; Return (Pop & Jump)
= [x31++]               
