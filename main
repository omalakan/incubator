; Ініціалізація пам'яті (тепер це безпечна підпрограма)

= S_RAM 0x00080000

:
    = x1 config.FREE_RAM_START
    = x2 config.RAM_MAX
    = x3 config.PAGE_SIZE

    ; Захист від дурня: якщо пам'яті немає, достроково виходимо ^
    ? x1 >= x2 ^

    > назва_каналу адреса_даних [адреса_каналів_модуля] [, таймаут] 
    < назва_каналу адреса_даних [адреса_каналів_модуля] [, таймаут] 

    ; Запити та очікування відповіді

    > @ назва_каналу адреса_даних статус [адреса_каналів_модуля] [, час_роз'єднання]
    ; Отримали запит
    < @ назва_каналу адреса_даних статус адреса_відповіді [адреса_каналів_модуля] [, час_роз'єднання] 
    ; Відповідь на запит
    > ^ адреса_відповіді адреса_даних статус [, час_роз'єднання] 


    = x5 config.FREE_LIST_HEAD
    = [x5] x1

: build_list
    = x4 x1 + x3
    
    ; Якщо дійшли до кінця RAM - ранній вихід з підпрограми
    ? x4 >= x2 ^
    
    = [x1] x4
    = x1 x4
    
    . build_list
    
; ФАЙЛ ЗАКІНЧИВСЯ. 
; Компілятор сам згенерує тут відновлення стеку та інструкцію RET.
