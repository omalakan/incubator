; Ініціалізація пам'яті (тепер це безпечна підпрограма)

x1 [config.FREE_RAM_START]
x2 [config.RAM_MAX]
x3 [config.PAGE_SIZE]

; Захист від дурня: якщо пам'яті немає, достроково виходимо (=)
? x1 >= x2 {
    =
}

x5 [config.FREE_LIST_HEAD]
[x5] x1

& {
    x4 x1 + x3
    
    ; Якщо дійшли до кінця RAM - ранній вихід з підпрограми
    ? x4 >= x2 {
        =
    }
    
    [x1] x4
    x1 x4
}    
    
; ФАЙЛ ЗАКІНЧИВСЯ. 
; Компілятор сам згенерує тут відновлення стеку та інструкцію RET.
